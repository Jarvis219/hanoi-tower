{
  "name": "thap-ha-noi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Stack Tower game with Hanoi street theme — built with Phaser 3 + TypeScript + Vite",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "i18next": "^26.3.0",
    "phaser": "^4.1.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
