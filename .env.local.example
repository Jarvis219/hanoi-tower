# Supabase project URL + anon key — copy from Supabase dashboard → Project Settings → API.
# Leave blank to run game in offline-only mode (localStorage cache, no leaderboard).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google AdSense — publisher ID + slot IDs (optional; no ads load without them).
# Format: ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_PUBLISHER_ID=
VITE_ADSENSE_BANNER_SLOT=
VITE_ADSENSE_INTERSTITIAL_SLOT=

# Dev helpers
VITE_DEV_UNLOCK_ALL=
